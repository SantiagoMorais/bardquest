{
  "name": "bardquest",
  "version": "0.1.0",
  "private": true,
  "author": "Felipe Santiago Morais",
  "scripts": {
    "dev": "concurrently \"next dev\" \"npm run types:watch\"",
    "types:watch": "tcm src --camelCase -p \"**/*.module.scss\" --watch",
    "types:generate": "tcm src --camelCase -p \"**/*.module.scss\"",
    "build": "npm run types:generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.14.0",
    "classnames": "^2.5.1",
    "next": "16.2.2",
    "prettier": "^3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "sass": "^1.98.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "typed-css-modules": "^0.9.1",
    "typescript": "^5"
  }
}
